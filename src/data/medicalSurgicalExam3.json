    {
      "id": 1,
      "questionText": "A nurse is caring for a client who has end-stage kidney disease (ESKD) and reports having shortness of breath and swelling in his lower extremities. Upon assessment, the nurse notes the client has crackles in his lungs and an elevated blood pressure. The nurse should suspect which of the following based on the client's manifestations?",
      "questionImage": null,
      "options": [
        "Hypovolemia",
        "Hypervolemia",
        "Hyperkalemia",
        "Hyponatremia"
      ],
      "correctAnswer": "Hypervolemia",
      "explanationText": "",
      "explanationImage": null
    },
    {
      "id": 2,
      "questionText": "A nurse is caring for a client who has a new arteriovenous (AV) graft in his left forearm. Which of the following techniques should the nurse use to assess the patency of this graft?",
      "questionImage": null,
      "options": [
        "Measure the client's blood pressure to ensure it is higher in the left arm than the right.",
        "Check the brachial and radial pulses of the left arm simultaneously.",
        "Auscultate the site for a bruit.",
        "Auscultate the antecubital fossa using a Doppler stethoscope."
      ],
      "correctAnswer": "Auscultate the site for a bruit.",
      "explanationText": "Auscultate the site for a bruit, then palpate for a thrill.",
      "explanationImage": null
    },
    {
      "id": 3,
      "questionText": "A nurse is caring for a client who is undergoing initial peritoneal dialysis. Which of the following should the nurse report immediately to the provider?",
      "questionImage": null,
      "options": [
        "Report of discomfort during dialysate inflow",
        "Dialysate fluid is slow to drain out.",
        "Dialysate leakage during inflow",
        "Purulent dialysate outflow"
      ],
      "correctAnswer": "Purulent dialysate outflow",
      "explanationText": "Peritonitis infection risk leading to sepsis risk (a life-threatening body-wide response to infection that causes organ dysfunction.)",
      "explanationImage": null
    },
    {
      "id": 4,
      "questionText": "A nurse is reviewing the medication record for a client who has chronic kidney disease. Which has potential to cause nephrotoxicity?",
      "questionImage": null,
      "options": [
        "Omeprazole.",
        "Vancomycin.",
        "Diphenhydramine.",
        "Ondansetron."
      ],
      "correctAnswer": "Vancomycin.",
      "explanationText": "Vancomycin and Metformin are major concerns",
      "explanationImage": null
    },
    {
      "id": 5,
      "questionText": "A nurse is caring for a client who is receiving peritoneal dialysis. The nurse should monitor the client for which of the following manifestations of peritonitis?",
      "questionImage": null,
      "options": [
        "Hyperactive bowel sounds.",
        "Increased urinary output",
        "Bradycardia.",
        "Nausea and vomiting."
      ],
      "correctAnswer": "Nausea and vomiting.",
      "explanationText": "Peritonitis Signs: ✅ Nausea and vomiting ✅ Abdominal pain/tenderness ✅ Fever ✅ Malaise ✅ Cloudy or purulent dialysate outflow (most important finding) ✅ Hypoactive bowel sounds",
      "explanationImage": null
    },
